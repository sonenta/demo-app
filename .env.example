# Verbumia missing:write API key (format: vrb_live_<prefix>.<secret>).
# Bound to the public demo sandbox project (slug: demo-public).
#
# The showcase overrides VerbumiaProvider.transport to visualize missing-key
# batches locally, so this token is NOT required for the demo to run. It is
# only used if the default POST transport (-> /v1/missing) is re-enabled.
#
# For deploys: inject from the bridge `secrets` peer
#   name=demo_public_missing_write_token  scope=verbumia
# (set it as a Vercel project env var). Never commit a real value.
VITE_VERBUMIA_TOKEN=

# Verbumia API base. Leave UNSET for the prod Vercel demo (defaults to
# https://api.verbumia.ca). Set to http://localhost:8820 to run the LIVE
# end-user feedback loop against the dev backend (demo-public project):
# tos -> server-minted sessionId -> getStrings -> ratings/suggestions.
# See kb topic sdk/demo-live-provisioning.
VITE_VERBUMIA_API_BASE=

# SDK realtime (Centrifugo subscribe + translations_published cache-bust) is
# DEV-VERSION ONLY (master ruling, ltm 341). A promoted PROD version has NO
# WS — freshness comes from the CDN ~60s cache. Missing-key push still works
# in both modes over HTTP, so leave both vars UNSET for the Vercel prod demo
# (it runs without a persistent WS — by design).
#
# Set to "true" ONLY for a local/dev-version realtime showcase:
VITE_VERBUMIA_LIVE_UPDATES=
# Centrifugo WS URL, consulted only when VITE_VERBUMIA_LIVE_UPDATES=true.
# Code default for local dev: ws://localhost:8830/connection/websocket
# (path "<host>/connection/websocket" is fixed). No prod value needed —
# prod deploy has no WS.
VITE_VERBUMIA_CENTRIFUGO_WS=
