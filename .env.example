# Sonenta missing:write API key (format: vrb_live_<prefix>.<secret>).
# Bound to the public demo sandbox project (slug: demo-public).
#
# The showcase overrides SonentaProvider.transport to visualize missing-key
# batches locally, so this token is NOT required for the demo to run. It is
# only used if the default POST transport (-> /v1/missing) is re-enabled.
#
# For deploys: inject from the bridge `secrets` peer
#   name=demo_public_missing_write_token  scope=sonenta
# (set it as a Vercel project env var). Never commit a real value.
VITE_SONENTA_TOKEN=

# Sonenta API base. Leave UNSET for the prod Vercel demo (defaults to
# https://api.sonenta.dev). Set to http://localhost:8820 to run the LIVE
# end-user feedback loop against the dev backend (demo-public project):
# tos -> server-minted sessionId -> getStrings -> ratings/suggestions.
# See kb topic sdk/demo-live-provisioning.
VITE_SONENTA_API_BASE=

# SDK realtime is DEV-VERSION ONLY (master ruling, ltm 341). In
# @sonenta/react-i18next@0.9.0 it moved OUT of the provider core and is now
# the @sonenta/realtime plugin (wired in src/App.tsx). A promoted PROD
# version has NO WS — freshness comes from the CDN ~60s cache. The plugin
# probes the version's dev/published state and stands down (console warning)
# on a published version. Missing-key push still works in both modes over
# HTTP, so leave all three UNSET for the Vercel prod demo (published `main`,
# CDN, no persistent WS — by design).
#
# Provider version slug (default `main` = published prod bundle). Set to a dev
# version slug for a dev/live showcase:
VITE_SONENTA_VERSION=
# Deployment env: `prod` (default, CDN) or `dev` (live runtime fetch +
# realtime-eligible). Set to `dev` together with a dev VITE_SONENTA_VERSION:
VITE_SONENTA_ENV=
# Centrifugo WS URL the @sonenta/realtime plugin dials on dev versions
# (path "<host>/connection/websocket" is fixed). Defaults to the prod node
# wss://rt.sonenta.dev/connection/websocket; for a local dev backend use
# ws://localhost:8830/connection/websocket:
VITE_SONENTA_RT_WS=
