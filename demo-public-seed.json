        "fr": "Détecteur de clés manquantes en runtime",
        "es": "Detector de claves faltantes en runtime"
      },
      "features.one.body": {
        "en": "The SDK reports every miss back to your dashboard with the exact key, namespace and locale — without a CI step or a static scan.",
        "fr": "Le SDK remonte chaque manque vers votre dashboard avec la clé exacte, le namespace et la locale — sans étape de CI, sans scan statique.",
        "es": "El SDK reporta cada fallo a tu dashboard con la clave exacta, el namespace y el idioma — sin paso de CI, sin escaneo estático."
      },
      "features.two.title": {
        "en": "MCP-native",
        "fr": "MCP natif",
        "es": "MCP nativo"
      },
      "features.two.body": {
        "en": "Your AI agents can read, propose and merge translations through a first-class MCP server — not a bolt-on REST wrapper.",
        "fr": "Vos agents IA peuvent lire, proposer et fusionner des traductions via un serveur MCP de première classe — pas un wrapper REST cosmétique.",
        "es": "Tus agentes IA pueden leer, proponer y fusionar traducciones vía un servidor MCP de primera clase — no un envoltorio REST."
      },
      "features.three.title": {
        "en": "Predictable pricing",
        "fr": "Tarification prévisible",
        "es": "Precios predecibles"
      },
      "features.three.body": {
        "en": "Flat tiers from the Hobby plan onward. Unlimited languages, no per-word fees, no surprise bills the day before launch.",
        "fr": "Paliers à prix fixe dès Hobby. Langues illimitées, aucun coût au mot, zéro mauvaise surprise la veille du lancement.",
        "es": "Tarifas planas desde el plan Hobby. Idiomas ilimitados, sin coste por palabra, sin sorpresas la víspera del lanzamiento."
      },
